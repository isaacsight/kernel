{
  "name": "@kernel.chat/kbot",
  "version": "3.10.0",
  "description": "The only AI agent that builds its own tools. Self-evolving terminal AI: 290 tools, 23 agents, 20 providers. Runtime tool forging via forge_tool, Forge Registry for community tools, autopoietic health monitoring, immune self-audit agent. Cost-aware model routing, fallback chains, Bayesian skill routing. Embedded llama.cpp, MCP server, programmatic SDK. MIT.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaacsight/kernel.git",
    "directory": "packages/kbot"
  },
  "homepage": "https://kernel.chat",
  "bugs": {
    "url": "https://github.com/isaacsight/kernel/issues"
  },
  "bin": {
    "kbot": "./dist/cli.js"
  },
  "main": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    },
    "./agent": {
      "import": "./dist/agent.js",
      "types": "./dist/agent.d.ts"
    },
    "./tools": {
      "import": "./dist/tools/index.js",
      "types": "./dist/tools/index.d.ts"
    },
    "./ui-adapter": {
      "import": "./dist/ui-adapter.js",
      "types": "./dist/ui-adapter.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
