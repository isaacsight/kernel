{
  "name": "@kernel.chat/kbot",
  "version": "4.5.0",
  "description": "Open-source terminal AI agent. 100+ specialist skills + audit-grade finance infra via @kernel.chat/kbot-finance. Content-addressed envelopes, hash-chained audit log, jurisdiction-aware regulatory verifier. The AI Intelligence Layer never produces the number. Fully local, fully sovereign. MIT.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaacsight/kernel.git",
    "directory": "packages/kbot"
  },
  "homepage": "https://kernel.chat",
  "bugs": {
    "url": "https://github.com/isaacsight/kernel/issues"
  },
  "bin": {
    "kbot": "dist/cli.js"
  },
  "main": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    },
    "./agent": {
      "import": "./dist/agent.js",
      "types": "./dist/agent.d.ts"
    },
    "./tools": {
      "import": "./dist/tools/index.js",
      "types": "./dist/tools/index.d.ts"
    },
    "./ui-adapter": {
      "import": "./dist/ui-adapter.js",
      "types": "./dist/ui-adapter.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node -e \"if(process.platform!=='win32')require('fs').chmodSync('dist/cli.js',0o755)\"",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "eval": "tsx eval/run.ts",
    "bounty": "tsx src/bounty/cli.ts",
    "bounty:poll": "tsx src/bounty/cli.ts poll",
    "bounty:watch": "tsx src/bounty/cli.ts watch"
  },
  "keywords": [
    "ai-agent",
    "cli-agent",
    "coding-agent",
    "autonomous-agent",
    "multi-agent",
    "ai-coding-assistant",
    "vibe-coding",
    "claude-code-alternative",
    "cursor-alternative",
    "copilot-alternative",
    "aider-alternative",
    "cline-alternative",
    "byok",
    "offline-ai",
    "local-first",
    "local-llm",
    "open-source",
    "multi-provider",
    "ollama",
    "mcp",
    "model-context-protocol",
    "tool-calling",
    "cli",
    "terminal",
    "developer-tools",
    "llm",
    "typescript"
  ],
  "author": "kernel.chat group",
  "license": "MIT",
  "dependencies": {
    "@kernel.chat/kbot-finance": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "marked": "^14.0.0",
    "marked-terminal": "^7.2.0",
    "nodemailer": "^8.0.3",
    "ora": "^8.1.0",
    "picomatch": "^4.0.4",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "node-llama-cpp": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.js.map",
    "!dist/**/*.d.ts.map",
    "skills/**/*.md",
    "README.md",
    "install.sh",
    "ollama-manifest.json"
  ]
}
