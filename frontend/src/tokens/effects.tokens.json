{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "borderRadius": {
    "$description": "Border radius scale",
    "none": { "$value": "0px", "$type": "dimension" },
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "xl": { "$value": "24px", "$type": "dimension" },
    "2xl": { "$value": "32px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "Pills, avatars" }
  },
  "borderWidth": {
    "none": { "$value": "0px", "$type": "dimension" },
    "thin": { "$value": "1px", "$type": "dimension" },
    "medium": { "$value": "2px", "$type": "dimension" },
    "thick": { "$value": "4px", "$type": "dimension" }
  },
  "shadow": {
    "$description": "Box shadow presets",
    "none": { "$value": "none", "$type": "shadow" },
    "sm": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px",
        "color": "rgba(0, 0, 0, 0.05)"
      },
      "$type": "shadow"
    },
    "md": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "2px",
        "blur": "8px",
        "spread": "0px",
        "color": "rgba(0, 0, 0, 0.08)"
      },
      "$type": "shadow"
    },
    "lg": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "16px",
        "spread": "0px",
        "color": "rgba(0, 0, 0, 0.1)"
      },
      "$type": "shadow"
    },
    "xl": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "8px",
        "blur": "32px",
        "spread": "0px",
        "color": "rgba(0, 0, 0, 0.12)"
      },
      "$type": "shadow"
    },
    "glow": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "10px",
        "spread": "0px",
        "color": "rgba(102, 181, 110, 0.3)"
      },
      "$type": "shadow",
      "$description": "Studio Green glow effect"
    },
    "glow-blue": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "10px",
        "spread": "0px",
        "color": "rgba(80, 128, 248, 0.3)"
      },
      "$type": "shadow",
      "$description": "Claude faction blue glow"
    },
    "glow-purple": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "10px",
        "spread": "0px",
        "color": "rgba(144, 96, 200, 0.3)"
      },
      "$type": "shadow",
      "$description": "Gemini faction purple glow"
    }
  },
  "opacity": {
    "0": { "$value": "0", "$type": "number" },
    "5": { "$value": "0.05", "$type": "number" },
    "10": { "$value": "0.1", "$type": "number" },
    "20": { "$value": "0.2", "$type": "number" },
    "30": { "$value": "0.3", "$type": "number" },
    "40": { "$value": "0.4", "$type": "number" },
    "50": { "$value": "0.5", "$type": "number" },
    "60": { "$value": "0.6", "$type": "number" },
    "70": { "$value": "0.7", "$type": "number" },
    "80": { "$value": "0.8", "$type": "number" },
    "90": { "$value": "0.9", "$type": "number" },
    "100": { "$value": "1", "$type": "number" }
  },
  "zIndex": {
    "$description": "Z-index scale for layering",
    "base": { "$value": "0", "$type": "number" },
    "dropdown": { "$value": "10", "$type": "number" },
    "sticky": { "$value": "20", "$type": "number" },
    "fixed": { "$value": "30", "$type": "number" },
    "modal-backdrop": { "$value": "40", "$type": "number" },
    "modal": { "$value": "50", "$type": "number" },
    "popover": { "$value": "60", "$type": "number" },
    "tooltip": { "$value": "70", "$type": "number" },
    "toast": { "$value": "80", "$type": "number" }
  }
}
