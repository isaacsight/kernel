{
    "manifest_version": 3,
    "name": "Does This Feel Right? - Capture",
    "version": "1.1",
    "description": "Capture signals and search your Studio OS directly from Chrome.",
    "permissions": [
        "activeTab",
        "contextMenus",
        "storage",
        "webNavigation",
        "tabs"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "omnibox": {
        "keyword": "dtfr"
    },
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    }
}