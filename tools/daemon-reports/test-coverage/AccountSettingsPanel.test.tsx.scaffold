import { describe, it, expect, vi } from 'vitest'
import { render, screen, fireEvent } from '@testing-library/react'
import AccountSettingsPanel from './AccountSettingsPanel'
import { User } from '@supabase/supabase-js'
import { useAccountSettings } from '../hooks/useAccountSettings'
import { useIdentityRecovery } from '../hooks/useIdentityRecovery'
import { useAuthContext } from '../providers/AuthProvider'

vi.mock('react-i18next', () => ({
  useTranslation: vi.fn().mockReturnValue({ t: (key) => key }),
}))

vi.mock('../hooks/useAccountSettings', () => ({
  useAccountSettings: vi.fn(),
}))

vi.mock('../hooks/useIdentityRecovery', () => ({
  useIdentityRecovery: vi.fn(),
}))

vi.mock('../providers/AuthProvider', () => ({
  useAuthContext: vi.fn().mockReturnValue({
    updateEmail: vi.fn(),
    updatePassword: vi.fn(),
    updateProfile: vi.fn(),
    getUserIdentities: vi.fn(),
    linkIdentity: vi.fn(),
    unlinkIdentity: vi.fn(),
  }),
}))

const mockUser: User = {
  id: '123',
  email: 'test@example.com',
} as User

describe('AccountSettingsPanel', () => {
  it('renders the component with user information', () => {
    useAccountSettings.mockReturnValue({
      displayName: 'Test User',
      avatarUrl: '',
      uploadAvatar: vi.fn(),
    })

    render(<AccountSettingsPanel user={mockUser} onClose={vi.fn()} onToast={vi.fn()} onSignOut={vi.fn()} onDeleteAccount={vi.fn()} />)

    expect(screen.getByText('Test User')).toBeInTheDocument()
    expect(screen.getByText('test@example.com')).toBeInTheDocument()
  })

  it('calls handleSendCode when send code button is clicked', async () => {
    const identity = {
      initiate: vi.fn().mockResolvedValue({ requestId: '123' }),
      sendChallenge: vi.fn(),
      loading: false,
      request: null,
    }
    useIdentityRecovery.mockReturnValue(identity)

    render(<AccountSettingsPanel user={mockUser} onClose={vi.fn()} onToast={vi.fn()} onSignOut={vi.fn()} onDeleteAccount={vi.fn()} />)

    const sendCodeButton = screen.getByText('security.sendCode')
    await fireEvent.click(sendCodeButton)

    expect(identity.initiate).toHaveBeenCalledWith('password_reset')
    expect(identity.sendChallenge).toHaveBeenCalledWith('123')
  })

  it('calls handleVerifyCode when verify code button is clicked', async () => {
    const identity = {
      request: { requestId: '123' },
      verify: vi.fn().mockResolvedValue(true),
      loading: false,
    }
    useIdentityRecovery.mockReturnValue(identity)

    render(<AccountSettingsPanel user={mockUser} onClose={vi.fn()} onToast={vi.fn()} onSignOut={vi.fn()} onDeleteAccount={vi.fn()} />)

    const verifyCodeInput = screen.getByRole('textbox')
    fireEvent.change(verifyCodeInput, { target: { value: '123456' } })

    const verifyCodeButton = screen.getByText('security.verifyCode')
    await fireEvent.click(verifyCodeButton)

    expect(identity.verify).toHaveBeenCalledWith('123', '123456')
  })

  it('renders admin tier badge when isAdmin is true', () => {
    useAccountSettings.mockReturnValue({
      displayName: 'Test User',
      avatarUrl: '',
      uploadAvatar: vi.fn(),
    })

    render(<AccountSettingsPanel user={mockUser} isAdmin={true} onClose={vi.fn()} onToast={vi.fn()} onSignOut={vi.fn()} onDeleteAccount={vi.fn()} />)

    expect(screen.getByText('subscription.admin')).toBeInTheDocument()
    const shieldIcon = screen.getByRole('img', { name: 'shield' })
    expect(shieldIcon).toBeInTheDocument()
  })

  it('calls onClose when close button is clicked', () => {
    const onClose = vi.fn()

    render(<AccountSettingsPanel user={mockUser} onClose={onClose} onToast={vi.fn()} onSignOut={vi.fn()} onDeleteAccount={vi.fn()} />)

    const closeButton = screen.getByRole('button', { name: 'close' })
    fireEvent.click(closeButton)

    expect(onClose).toHaveBeenCalled()
  })

  it('calls onSignOut when sign out button is clicked', () => {
    const onSignOut = vi.fn()

    render(<AccountSettingsPanel user={mockUser} onClose={vi.fn()} onToast={vi.fn()} onSignOut={onSignOut} onDeleteAccount={vi.fn()} />)

    const signOutButton = screen.getByRole('button', { name: 'signOut' })
    fireEvent.click(signOutButton)

    expect(onSignOut).toHaveBeenCalled()
  })

  it('calls onDeleteAccount when delete account button is clicked', () => {
    const onDeleteAccount = vi.fn()

    render(<AccountSettingsPanel user={mockUser} onClose={vi.fn()} onToast={vi.fn()} onSignOut={vi.fn()} onDeleteAccount={onDeleteAccount} />)

    const deleteAccountButton = screen.getByRole('button', { name: 'deleteAccount' })
    fireEvent.click(deleteAccountButton)

    expect(onDeleteAccount).toHaveBeenCalled()
  })

  it('disables send code button when identity is loading', () => {
    useIdentityRecovery.mockReturnValue({
      initiate: vi.fn(),
      sendChallenge: vi.fn(),
      loading: true,
      request: null,
    })

    render(<AccountSettingsPanel user={mockUser} onClose={vi.fn()} onToast={vi.fn()} onSignOut={vi.fn()} onDeleteAccount={vi.fn()} />)

    const sendCodeButton = screen.getByText('security.sendCode')
    expect(sendCodeButton).toBeDisabled()
  })
})
