```typescript
import { describe, it, expect, vi } from 'vitest'
import { render, screen, fireEvent } from '@testing-library/react'
import { getAllSpecialists, type Specialist } from '../agents/specialists'

vi.mock('../agents/specialists', () => ({
  getAllSpecialists: vi.fn(),
}))

const mockSpecialists: Specialist[] = [
  { id: 'kernel', name: 'Kernel', icon: '\u2694\uFE0F', color: '#FF5733' },
  // Add more specialists as needed
]

getAllSpecialists.mockReturnValue(mockSpecialists)

describe('AgentPicker', () => {
  const mockOnSelect = vi.fn()
  const renderComponent = (props: Partial<AgentPickerProps> = {}) => {
    return render(
      <AgentPicker
        selectedAgent={null}
        onSelect={mockOnSelect}
        disabled={false}
        {...props}
      />
    )
  }

  it('renders the component', () => {
    renderComponent()
    expect(screen.getByLabelText('Choose agent')).toBeInTheDocument()
  })

  it('displays the selected agent when provided', () => {
    renderComponent({ selectedAgent: 'kernel' })
    const button = screen.getByLabelText('Choose agent')
    expect(button).toHaveTextContent('\u2694\uFE0F')
    expect(button).toHaveStyle('color: #FF5733')
  })

  it('opens the dropdown when clicked', () => {
    renderComponent()
    fireEvent.click(screen.getByLabelText('Choose agent'))
    expect(screen.getByRole('button', { name: 'Auto' })).toBeInTheDocument()
  })

  it('selects an agent from the dropdown', () => {
    renderComponent()
    fireEvent.click(screen.getByLabelText('Choose agent'))
    fireEvent.click(screen.getByText('General chat'))
    expect(mockOnSelect).toHaveBeenCalledWith('kernel')
  })

  it('calls onSelect with null when "Auto" is selected', () => {
    renderComponent()
    fireEvent.click(screen.getByLabelText('Choose agent'))
    fireEvent.click(screen.getByRole('button', { name: 'Auto' }))
    expect(mockOnSelect).toHaveBeenCalledWith(null)
  })

  it('disables the button when disabled prop is true', () => {
    renderComponent({ disabled: true })
    const button = screen.getByLabelText('Choose agent')
    expect(button).toBeDisabled()
  })

  it('closes the dropdown when clicking outside', () => {
    renderComponent()
    fireEvent.click(screen.getByLabelText('Choose agent'))
    fireEvent.click(document.body)
    expect(screen.queryByRole('button', { name: 'Auto' })).not.toBeInTheDocument()
  })
})
