import { describe, it, expect, vi } from 'vitest'
import { render, screen, fireEvent } from '@testing-library/react'
import { BriefingPanel } from './BriefingPanel'
import { supabase } from '../engine/SupabaseClient'
import { generateBriefing } from '../engine/BriefingGenerator'

vi.mock('../engine/SupabaseClient', () => ({
  supabase: {
    from: vi.fn().mockReturnThis(),
    select: vi.fn().mockReturnThis(),
    eq: vi.fn().mockReturnThis(),
    order: vi.fn().mockReturnThis(),
    limit: vi.fn().mockReturnThis(),
    gte: vi.fn().mockReturnThis(),
    insert: vi.fn().mockReturnThis(),
    delete: vi.fn().mockReturnThis(),
    update: vi.fn().mockReturnThis(),
  },
}))

vi.mock('../engine/BriefingGenerator', () => ({
  generateBriefing: vi.fn(),
}))

describe('BriefingPanel', () => {
  const mockProps = {
    userId: 'test-user-id',
    userMemory: null,
    kgEntities: [],
    onClose: vi.fn(),
    onToast: vi.fn(),
    isPro: true,
    historyDays: null,
  }

  it('renders the component', () => {
    render(<BriefingPanel {...mockProps} />)
    expect(screen.getByText(/good morning/i)).toBeInTheDocument()
  })

  it('loads briefings on mount', async () => {
    const mockData = [{ id: '1', content: 'Test briefing' }]
    vi.mocked(supabase.from).mockReturnThis()
    vi.mocked(supabase.select).mockResolvedValue({ data: mockData, error: null })

    render(<BriefingPanel {...mockProps} />)

    await screen.findByText('Test briefing')
  })

  it('generates a new briefing', async () => {
    const mockBriefing = { id: '2', content: 'New briefing' }
    vi.mocked(generateBriefing).mockResolvedValue(mockBriefing)
    vi.mocked(supabase.from).mockReturnThis()
    vi.mocked(supabase.insert).mockResolvedValue({ error: null })

    render(<BriefingPanel {...mockProps} />)

    const generateButton = screen.getByRole('button', { name: /generate/i })
    fireEvent.click(generateButton)

    await screen.findByText('New briefing')
  })

  it('deletes a briefing', async () => {
    const mockData = [{ id: '1', content: 'Test briefing' }]
    vi.mocked(supabase.from).mockReturnThis()
    vi.mocked(supabase.select).mockResolvedValue({ data: mockData, error: null })
    vi.mocked(supabase.delete).mockResolvedValue({ error: null })

    render(<BriefingPanel {...mockProps} />)

    await screen.findByText('Test briefing')

    const deleteButton = screen.getByRole('button', { name: /delete/i })
    fireEvent.click(deleteButton)

    expect(mockProps.onToast).toHaveBeenCalledWith(/removed/i)
  })

  it('handles briefing generation failure', async () => {
    vi.mocked(generateBriefing).mockRejectedValue(new Error('Failed to generate'))
    vi.mocked(supabase.from).mockReturnThis()

    render(<BriefingPanel {...mockProps} />)

    const generateButton = screen.getByRole('button', { name: /generate/i })
    fireEvent.click(generateButton)

    expect(mockProps.onToast).toHaveBeenCalledWith(/failed/i)
  })

  it('marks briefing as read when selected', async () => {
    const mockData = [{ id: '1', content: 'Test briefing' }]
    vi.mocked(supabase.from).mockReturnThis()
    vi.mocked(supabase.select).mockResolvedValue({ data: mockData, error: null })
    vi.mocked(supabase.update).mockResolvedValue({ error: null })

    render(<BriefingPanel {...mockProps} />)

    await screen.findByText('Test briefing')

    expect(vi.mocked(supabase.update)).toHaveBeenCalled()
  })
})
