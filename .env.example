# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
STUDIO_NODE_API_KEY=sk-antigravity

# Infrastructure
STRIPE_SECRET_KEY=your_stripe_secret_key_here
CONVERTKIT_API_SECRET=your_convertkit_api_secret_here

# Social Media
TWITTER_CONSUMER_KEY=your_twitter_consumer_key_here
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Email Configuration (for notifications)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password_here

# Substack Integration (optional)
SUBSTACK_EMAIL=your_substack_email@example.com
SUBSTACK_PASSWORD=your_substack_password_here
